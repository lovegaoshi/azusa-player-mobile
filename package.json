{
  "name": "azusa-player-mobile",
  "version": "4.2.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:ide": "open -a /Applications/Android\\ Studio.app ./android",
    "ios": "react-native run-ios",
    "ios:ide": "open ios/*.xcworkspace/",
    "windows": "react-native run-windows",
    "start": "react-native start",
    "test": "jest",
    "lint": "yarn compile; yarn ci:lint; yarn ci:format",
    "fresh": "rm -rf node_modules && yarn && git submodule update --recursive --remote",
    "types": "tsc --noEmit true",
    "ci:lint": "eslint src --max-warnings=0",
    "ci:format": "prettier --check src",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "yarn run compile",
    "pretest": "yarn run compile",
    "prettify": "prettier --write ./src",
    "build": "yarn install && yarn postinstall && cd ./nodejs-assets/nodejs-project && npm i && cd ../.. && yarn compile",
    "ios:build": "yarn build && cd ios && rm Podfile.lock && pod install --repo-update && cd ..",
    "dep": "yarn upgrade-interactive && yarn postinstall",
    "release": "git switch master && git pull && python release_bump.py",
    "postinstall": "patch-package --exclude 'nothing'",
    "export-android": "mkdir -p android/output && react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/output/index.android.bundle --assets-dest android/output --sourcemap-output android/sourcemap.js && cd android && find output -type f | zip index.android.bundle.zip -@ && cd .. && rm -rf android/output && rm -rf android/sourcemap.js",
    "export-ios": "mkdir -p ios/output && react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/output/main.jsbundle --assets-dest ios/output --sourcemap-output ios/sourcemap.js && cd ios && find output -type f | zip main.jsbundle.zip -@ && cd .. && rm -rf ios/output && rm -rf ios/sourcemap.js",
    "ota": "yarn export-android; yarn export-ios; mkdir -p bundles; mv android/index.android.bundle.zip bundles; mv ios/main.jsbundle.zip bundles; python3 scripts/hashyarnlock.py",
    "sql": "npx drizzle-kit generate"
  },
  "codegenConfig": {
    "name": "NativeNoxModuleSpec",
    "type": "modules",
    "jsSrcsDir": "specs",
    "android": {
      "javaPackageName": "com.nativenoxmodule"
    }
  },
